{
  "$schema": "https://react.doctor/schema/config.json",
  "ignore": {
    "overrides": [
      {
        "files": ["convex/**"],
        "rules": [
          "deslop/unused-export",
          "deslop/unused-file",
          "react-doctor/async-defer-await"
        ]
      },
      {
        "files": ["convex/crm/metricAggregates.ts"],
        "rules": ["react-doctor/async-await-in-loop"]
      },
      {
        "files": [
          "src/lib/auth-client.js",
          "src/lib/auth-server.js",
          "src/lib/auth-sign-in-targets.js",
          "src/lib/email/send.js",
          "src/lib/razorpay.js",
          "src/lib/portal/**",
          "src/data/**"
        ],
        "rules": ["deslop/unused-export"]
      }
    ]
  }
}
