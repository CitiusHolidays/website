{
  "name": "citius-travel-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun --bun next dev --turbopack",
    "dev:reset": "rm -rf .next && bun run dev",
    "dev:webpack": "bun --bun next dev --webpack",
    "build": "bunx convex codegen && bun --bun next build",
    "start": "bun --bun next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "bun test",
    "check": "bun run lint && bun test",
    "perf:hero-baseline": "node bin/perf-hero-baseline.mjs",
    "optimize-images": "node scripts/full-optimize-images.mjs",
    "encode:hero": "powershell -ExecutionPolicy Bypass -File ./bin/encode-hero.ps1",
    "convex:dev": "bunx convex dev",
    "convex:codegen": "bunx convex codegen",
    "auth:schema:generate": "bunx @better-auth/cli generate --config ./convex/betterAuth/auth.ts --output ./convex/betterAuth/schema.ts",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.12.3",
    "@openrouter/ai-sdk-provider": "^2.9.1",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@sanity/image-url": "^2.1.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.204",
    "better-auth": "1.6.18",
    "convex": "^1.41.0",
    "dompurify": "^3.4.10",
    "exceljs": "^4.4.0",
    "html-react-parser": "^6.1.3",
    "lucide-react": "^1.18.0",
    "motion": "^12.40.0",
    "motion-plus": "^1.5.1",
    "next": "16.2.9",
    "next-sanity": "^13.1.0",
    "razorpay": "^2.9.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "resend": "^6.12.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@tailwindcss/postcss": "^4.3.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "tailwindcss": "^4.3.1"
  }
}
