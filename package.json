{
  "name": "citius-travel-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun --bun next dev --turbopack",
    "dev:reset": "rm -rf .next && bun run dev",
    "dev:webpack": "bun --bun next dev --webpack",
    "build": "bunx convex codegen --typecheck enable && bun --bun next build",
    "start": "bun --bun next start",
    "lint": "ultracite check",
    "lint:fix": "ultracite fix",
    "lint:doctor": "ultracite doctor",
    "lint:ratchet": "bun config/release/lint-ratchet.ts",
    "lint:ratchet:update": "bun config/release/lint-ratchet.ts --write-baseline",
    "format": "ultracite fix",
    "typecheck": "next typegen && tsc --noEmit --project tsconfig.json",
    "convex:typecheck": "cd convex && bunx tsc --noEmit",
    "test": "bun test",
    "check": "bun run lint && bun run lint:ratchet && bun test",
    "check:fast": "bun test",
    "dev:all": "bun run convex:dev & bun run dev",
    "config:check": "bun test config/release/release-contract.test.ts",
    "diff:check": "bun config/release/check-diff-hygiene.ts",
    "ai:benchmark": "bun scripts/benchmark-ai-runtime.ts",
    "ai:config-check": "bun config/release/ai-runtime-config.ts",
    "assets:check": "bun config/release/check-public-assets.ts",
    "smoke:browser": "bun scripts/browser-smoke.ts",
    "optimize-images": "node scripts/full-optimize-images.mjs",
    "convex:dev": "bunx convex dev",
    "convex:codegen": "bunx convex codegen",
    "auth:schema:generate": "bunx @better-auth/cli generate --config ./convex/betterAuth/auth.ts --output ./convex/betterAuth/schema.ts",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.12.5",
    "@openrouter/ai-sdk-provider": "^3.0.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.10",
    "@sanity/image-url": "^2.1.1",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^7.0.18",
    "better-auth": "1.6.23",
    "clsx": "^2.1.1",
    "convex": "^1.42.1",
    "effect": "^3.21.4",
    "exceljs": "^4.4.0",
    "isomorphic-dompurify": "^3.19.0",
    "lucide-react": "^1.23.0",
    "motion": "^12.42.2",
    "motion-plus": "^1.5.1",
    "next": "^16.3.0-preview.5",
    "next-sanity": "^13.1.1",
    "razorpay": "^2.9.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "resend": "^6.17.2",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "ultracite": "7.9.0"
  },
  "overrides": {
    "ws": "8.21.0"
  }
}
