{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "!convex/_generated",
      "!convex/betterAuth/_generated",
      "!citius-blog/dist",
      "!citius-blog/.next",
      "!tools"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "correctness": {
        "noUnusedFunctionParameters": "warn",
        "noUnusedVariables": "warn",
        "noUndeclaredVariables": "error",
        "useExhaustiveDependencies": "warn"
      },
      "suspicious": {
        "noEmptyBlockStatements": "warn",
        "noArrayIndexKey": "warn",
        "noBitwiseOperators": "warn",
        "noEqualsToNull": "warn",
        "noEvolvingTypes": "warn",
        "noExplicitAny": "off",
        "noLeakedRender": "warn",
        "noNestedPromises": "warn",
        "noReturnAssign": "warn",
        "noShadow": "warn",
        "noUnnecessaryConditions": "warn",
        "noUnusedExpressions": "warn",
        "useArraySortCompare": "warn",
        "useAwait": "warn"
      },
      "a11y": {
        "noSvgWithoutTitle": "off",
        "useKeyWithClickEvents": "off",
        "useButtonType": "warn"
      },
      "style": {
        "noExportedImports": "warn",
        "noIncrementDecrement": "warn",
        "noMultiAssign": "warn",
        "noNestedTernary": "warn",
        "noNonNullAssertion": "off",
        "noSubstr": "warn",
        "useAtIndex": "warn",
        "useConsistentArrayType": "warn",
        "useConsistentTypeDefinitions": "warn",
        "useDefaultParameterLast": "warn",
        "useDefaultSwitchClause": "warn",
        "useDestructuring": "warn",
        "useErrorCause": "warn",
        "useFilenamingConvention": "off",
        "useNodejsImportProtocol": "warn"
      },
      "performance": {
        "noAwaitInLoops": "warn",
        "noBarrelFile": "warn",
        "noJsxPropsBind": "warn",
        "noNamespaceImport": "warn",
        "useTopLevelRegex": "warn"
      },
      "complexity": {
        "noExcessiveCognitiveComplexity": "warn",
        "noRedundantDefaultExport": "warn",
        "noUselessFragments": "warn",
        "noVoid": "warn",
        "useOptionalChain": "warn"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "extends": [
    "ultracite/biome/core",
    "ultracite/biome/react",
    "ultracite/biome/next"
  ]
}
