{
  "buildCommand": "bunx convex deploy --cmd 'bun --bun next build'",
  "headers": [
    {
      "source": "/(.*\\.mp4)",
      "headers": [
        { "key": "Accept-Ranges", "value": "bytes" },
        { "key": "Content-Type", "value": "video/mp4" }
      ]
    }
  ],
  "bunVersion": "1.x",
  "regions": ["bom1"]
}
